{
  "name": "node-whisper",
  "description": "A binding for OpenAI's Whisper Speech-to-Text system, supporting async operations.",
  "version": "2026.03.02",
  "author": {
    "email": "simonegauli@gmail.com",
    "name": "Simone Gauli"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Pnlvfx/node-whisper.git"
  },
  "license": "MIT",
  "type": "module",
  "keywords": [
    "OpenAI",
    "Whisper",
    "Transcript",
    "Audio",
    "Speech",
    "Speech-to-Text",
    "STT",
    "TTS",
    "SRT",
    "Captions",
    "Subtitles"
  ],
  "exports": {
    ".": {
      "types": "./dist/whisper.d.ts",
      "import": "./dist/whisper.js"
    }
  },
  "scripts": {
    "tsc": "tsc --noEmit",
    "unused": "node tools/unused.ts",
    "lint": "eslint",
    "build": "rimraf dist && eslint && tsc -p tsconfig.build.json",
    "prepack": "yarn build",
    "prepublishOnly": "yarn test && eslint",
    "update": "yarn upgrade-interactive",
    "reference": "node tools/reference.ts",
    "test": "rimraf coverage && jest --coverage"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "devDependencies": {
    "@goatjs/dbz": "^1.51.0",
    "@goatjs/node": "^1.71.0",
    "@goatjs/node-eslint": "^1.45.0",
    "@goatjs/rimraf": "^1.71.0",
    "@goatjs/ts-unused-exports": "1.71.0",
    "@goatjs/typescript-config": "1.71.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.9.0",
    "eslint": "^9.14.0",
    "husky": "^9.1.6",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  },
  "packageManager": "yarn@4.12.0+sha512.f45ab632439a67f8bc759bf32ead036a1f413287b9042726b7cc4818b7b49e14e9423ba49b18f9e06ea4941c1ad062385b1d8760a8d5091a1a31e5f6219afca8"
}
